# ══════════════════════════════════════════════════════════════
# Frontline CRM — Environment Variables
# Copy this file to backend/.env and fill in your real values.
# NEVER commit backend/.env to git.
# ══════════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── DATABASE (MongoDB Atlas) ─────────────────────────────────
# Get this from: MongoDB Atlas → Cluster → Connect → Connect your application
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/frontline_crm?retryWrites=true&w=majority
MONGO_URI=mongodb://atlas-sql-68847f5712f51b72d921b961-tymqib.a.query.mongodb.net/MERN?ssl=true&authSource=admin

# ─── JWT ──────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_64_CHARACTER_HEX_STRING
JWT_EXPIRES_IN=7d

# ─── SMTP (Email Sending via Gmail) ───────────────────────────
# Use a Gmail App Password (NOT your regular Gmail password)
# Setup: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=frontlineislandbarandgrill1@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM_NAME=Frontline Island Bar & Grill
SMTP_FROM_EMAIL=frontlineislandbarandgrill1@gmail.com

# ─── FRONTEND URL (for CORS) ──────────────────────────────────
# Set this to your Netlify URL if deploying frontend separately.
# If serving frontend from the same Render server, leave as empty or set to your Render URL.
# Multiple URLs allowed, comma-separated:
FRONTEND_URL=https://frontlinecateringcrm.netlify.app
